{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GrantAtlas",
  "version": "1.2.0-rc.1",
  "identifier": "xin.liubo.patentagent",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix frontend run build && scripts/build_backend_sidecar.sh",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "权衡 GrantAtlas",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend": "backend",
      "../build/backend/patentagent-backend": "patentagent-backend"
    },
    "category": "Productivity",
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
