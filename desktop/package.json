{
  "name": "patents-agent-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop runtime skeleton for PatentAgent",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "clean": "rm -rf dist-electron"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "electron": "^32.2.0",
    "typescript": "^5.6.0"
  }
}
